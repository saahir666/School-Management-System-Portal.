from school import SchoolManagementSystem
def main(): 
    system = SchoolManagementSystem
    
    print("==== Enter Teacher Information ====")
    
    for i in range(1):
        system.add_teacher()
        
        
    print("==== Enter Student Information ==== ")
    for i in range(1): 
        system.add_student()
        
        
    system.display_all()
    system.save_to_file()
    
if __name__ == "__main__": 
    main()    